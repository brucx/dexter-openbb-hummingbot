# =============================================================================
# dexter-openbb-hummingbot configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -- LLM Provider (at least one required) --
# Dexter supports multiple providers. Set the key for whichever you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=

# -- Dexter model selection --
# Examples: gpt-5.4, claude-sonnet-4-20250514, gemini-2.5-pro
DEXTER_MODEL=claude-sonnet-4-20250514

# -- Financial data (used by Dexter's built-in finance tools) --
# FINANCIAL_DATASETS_API_KEY=

# -- Search (at least one recommended) --
# EXASEARCH_API_KEY=
# TAVILY_API_KEY=

# -- OpenBB data providers --
# Free tier: yfinance works without a key for quotes, price history,
# financials, and company news.
#
# For broader news coverage (world news), add a provider key below.
# OpenBB expects specific env var names; the bridge also accepts the
# common aliases shown in parentheses.
#
# FMP_API_KEY=
# POLYGON_API_KEY=
# FRED_API_KEY=
# TIINGO_TOKEN=              (bridge also accepts TIINGO_API_KEY)
# BENZINGA_API_KEY=
# INTRINIO_API_KEY=

# Default OpenBB provider (used when no specific provider is requested)
OPENBB_DEFAULT_PROVIDER=yfinance

# -- OpenBB connection --
# If running OpenBB as a REST API server instead of subprocess bridge:
# OPENBB_API_URL=http://127.0.0.1:6900

# -- Paper trading defaults --
PAPER_TRADE_STARTING_BALANCE_USDT=10000
PAPER_TRADE_EXCHANGE=binance
